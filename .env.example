# Copy to .env and adjust. up.sh reads this.

# External redis address the LiveKit server uses. With network_mode: host the
# container shares the host's network, so redis on the same box = localhost.
REDIS_ADDR=localhost:6379

# Pinned server image. Find current stable:
#   docker run --rm livekit/livekit-server:latest --version
LIVEKIT_IMAGE=livekit/livekit-server:v1.12
